<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Miel Pura & Natural | Elixir de la Colmena</title>
    <!-- Tailwind CSS via CDN -->
    <script src="https://tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com"></script>
    <style>
        .glass { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); }
        .hover-scale { transition: transform 0.3s ease; }
        .hover-scale:hover { transform: scale(1.05); }
    </style>
</head>
<body class="bg-amber-50 text-slate-900 font-sans leading-relaxed">

    <!-- Navegación -->
    <nav class="fixed w-full z-50 glass border-b border-amber-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <i data-lucide="beaker" class="text-amber-600"></i>
                    <span class="font-bold text-xl tracking-tight uppercase">MielReal</span>
                </div>
                <div class="hidden md:flex space-x-8 font-medium">
                    <a href="#inicio" class="hover:text-amber-600 transition">Inicio</a>
                    <a href="productos.html" class="hover:text-amber-600 transition">Productos</a>
                    <a href="#beneficios" class="hover:text-amber-600 transition">Beneficios</a>
                    <a href="contacto.html" class="hover:text-amber-600 transition">Contacto</a>
                </div>
                <a href="https://wa.me" class="bg-amber-600 text-white px-5 py-2 rounded-full font-semibold hover:bg-amber-700 transition shadow-lg">Pedir Ahora</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="inicio" class="pt-32 pb-20 px-4">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2 space-y-6">
                <span class="bg-amber-200 text-amber-800 text-xs font-bold px-3 py-1 rounded-full uppercase">100% Orgánica</span>
                <h1 class="text-5xl md:text-7xl font-black text-slate-900 leading-tight">
                    Del panal a <span class="text-amber-600">tu mesa.</span>
                </h1>
                <p class="text-lg text-slate-600 max-w-md">
                    Descubre la pureza de nuestra miel cruda, recolectada de forma sostenible para conservar todas sus propiedades curativas y sabor ancestral.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="#productos" class="bg-slate-900 text-white px-8 py-4 rounded-xl font-bold hover:bg-slate-800 transition flex items-center gap-2">
                        Ver Catálogo <i data-lucide="arrow-right" class="w-5 h-5"></i>
                    </a>
                </div>
            </div>
            <div class="md:w-1/2 relative">
                <!-- Reemplazar el src con tu link de ImgBB -->
                <img src="https://unsplash.com" alt="Miel Natural" class="rounded-3xl shadow-2xl hover-scale">
                <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl flex items-center gap-4">
                    <div class="bg-amber-100 p-3 rounded-full"><i data-lucide="shield-check" class="text-amber-600"></i></div>
                    <div><p class="font-bold text-sm">Certificado Bio</p><p class="text-xs text-slate-500">Sin aditivos químicos</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Sección de Productos (Preview) -->
    <section id="productos" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Nuestras Variedades</h2>
                <p class="text-slate-500">Selección premium de temporada</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Producto 1 -->
                <div class="group border border-slate-100 rounded-3xl p-4 hover:shadow-2xl transition duration-500">
                    <div class="overflow-hidden rounded-2xl mb-6">
                        <img src="https://unsplash.com" alt="Miel de Azahar" class="w-full h-64 object-cover group-hover:scale-110 transition duration-500">
                    </div>
                    <h3 class="text-xl font-bold mb-2">Miel de Azahar</h3>
                    <p class="text-slate-600 text-sm mb-4">Aroma floral intenso, ideal para endulzar tus mañanas.</p>
                    <div class="flex justify-between items-center">
                        <span class="text-2xl font-black text-amber-600">$12.00</span>
                        <a href="https://stripe.com" class="bg-amber-100 text-amber-700 p-3 rounded-lg hover:bg-amber-600 hover:text-white transition">
                            <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Otros productos seguirían esta estructura -->
            </div>
        </div>
    </section>

    <!-- Footer Simple -->
    <footer class="bg-slate-900 text-white py-12">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p class="text-slate-400">&copy; 2024 MielReal. Cosechada con amor.</p>
        </div>
    </footer>

    <!-- Inicialización de Iconos -->
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
